# Copy to .env. Only non-secret config lives here.
# The client secret and tokens go in the macOS Keychain:
#   security add-generic-password -U -a "$USER" -s whoop-client-secret -w <SECRET>
# (tokens are managed automatically under service "whoop-tokens")
WHOOP_CLIENT_ID=<PLACEHOLDER>
WHOOP_REDIRECT_URI=http://localhost:8787/callback
